{
  "schema_version": 1,
  "suite_id": "h2h_llm_tldr_vs_contextplus_v1",
  "tool_id": "llm-tldr",
  "display_name": "llm-tldr",
  "version_capture": {
    "command": ["uv", "run", "tldrf", "--version"],
    "fallback_command": ["uv", "run", "python", "-c", "import tldr; print(getattr(tldr, '__version__', 'unknown'))"]
  },
  "capabilities": {
    "retrieval": true,
    "impact": true,
    "slice": true,
    "complexity": true,
    "data_flow": true
  },
  "commands": {
    "retrieval": {
      "description": "Natural-language retrieval over indexed corpus.",
      "template": "uv run tldrf semantic search \"{query}\" --path {repo_root} --k {top_k}"
    },
    "impact": {
      "description": "Caller-set impact analysis for a function scoped by file.",
      "template": "uv run tldrf impact \"{function}\" \"{repo_root}\" --file \"{file}\""
    },
    "slice": {
      "description": "Backward slice at line-level granularity.",
      "template": "uv run tldrf slice \"{file_abs}\" \"{function}\" {target_line}"
    },
    "complexity": {
      "description": "Cyclomatic complexity via CFG extraction.",
      "template": "uv run tldrf cfg \"{file_abs}\" \"{function}\""
    },
    "data_flow": {
      "description": "Variable-level data-flow graph extraction.",
      "template": "uv run tldrf dfg \"{file_abs}\" \"{function}\""
    }
  },
  "budget_policy": {
    "max_payload_tokens": "enforced_by_benchmark_harness",
    "max_payload_bytes": "enforced_by_benchmark_harness"
  },
  "notes": [
    "This profile declares native support for all benchmark categories.",
    "The benchmark harness truncates payloads to common token budgets if tool output exceeds budget."
  ]
}
